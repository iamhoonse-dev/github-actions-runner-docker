# GitHub Personal Access Token (required)
# Classic token: needs 'repo' scope
# Fine-grained token: needs 'Administration' read/write for the repository
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Target repository (required, format: owner/repo)
GITHUB_REPOSITORY=owner/repo

# Runner name (optional, defaults to 'docker-runner')
RUNNER_NAME=docker-runner

# Runner labels (optional, defaults to 'self-hosted,linux,docker')
RUNNER_LABELS=self-hosted,linux,docker